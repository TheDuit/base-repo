APP_ENV=local
SYSTEM_MANIFEST_PATH=/app/system.manifest.json
JWT_SECRET=replace-with-a-local-development-secret
JWT_EXPIRES_IN_SECONDS=3600
CORS_ORIGIN=http://localhost:3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=base_system
POSTGRES_PASSWORD=base_system_local
POSTGRES_DB=base_system

ADMIN_BOOTSTRAP_ON_STARTUP=true
ADMIN_EMAIL=admin@base.local
ADMIN_PASSWORD=replace-with-a-generated-strong-admin-password
ADMIN_NAME=Back Office Admin
ADMIN_ROTATE_PASSWORD=false

AWS_REGION=us-east-1
DYNAMODB_ENDPOINT=http://dynamodb:8000
S3_ENDPOINT=http://localstack:4566
S3_BUCKET=base-system-local

NEXT_PUBLIC_API_URL=http://localhost:4000/api
